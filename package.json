{
  "name": "nodejsexamples",
  "version": "1.0.0",
  "description": "This Project explains all Node JS examples",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test:unit": "jest --coverage",
    "test:integration": "echo integration test",
    "test:e2e": "echo e2e test"
  },
  "jest": {
    "reporters": [
      "default",
      ["jest-junit", {
        "outputDirectory": "reports",
        "outputName": "junit.xml"
      }]
  ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "jest-junit": {
    "outputDirectory": "./reports",
    "outputName": "junit.xml"
  },
  "dependencies": {
    "express": "^4.16.4"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "jest-junit": "^16.0.0"
  }
}
